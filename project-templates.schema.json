{
  "$schema": "root.schema.json",
  "$id": "https://meepleek.com/schema/project-templates.schema.json",
  "title": "MeepleekProjectTemplates",
  "type": "object",
  "properties": {
    "command_templates": {
      "type": "object",
      "additionalProperties": {
        "$ref": "defs.schema.json#/$defs/MappedCommand"
      }
    },
    "command_config_templates": {
      "type": "object",
      "additionalProperties": {
        "$ref": "defs.schema.json#/$defs/ProjectCommandConfig"
      }
    },
    "status_pane_command_templates": {
      "type": "object",
      "additionalProperties": {
        "$ref": "defs.schema.json#/$defs/StatusPaneCommand"
      }
    },
    "external_config_templates": {
      "type": "object",
      "additionalProperties": {
        "$ref": "defs.schema.json#/$defs/ExternalCommandConfig"
      }
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "command_templates",
    "command_config_templates",
    "status_pane_command_templates",
