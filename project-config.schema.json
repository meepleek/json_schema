{
  "$schema": "root.schema.json",
  "$id": "https://meepleek.com/schema/project-config.schema.json",
  "title": "MeepleekProjectConfig",
  "allOf": [
    {
      "$ref": "#/$defs/ProjectBase"
    }
  ],
  "properties": {
    "category": {
      "$ref": "defs.schema.json#/$defs/ProjectCategory"
    },
    "nested_projects": {
      "$ref": "#/$defs/NestedProjectsConfig"
    },
    "main_worktree_path": {
      "type": "string",
      "format": "uri-reference"
    },
    "command_templates": {
      "type": "object",
      "additionalProperties": {
        "$ref": "defs.schema.json#/$defs/RunnableCommand"
      }
    },
    "command_config_templates": {
      "type": "object",
      "additionalProperties": {
        "$ref": "defs.schema.json#/$defs/ProjectCommandConfig"
      }
    },
    "status_pane_command_templates": {
      "type": "object",
      "additionalProperties": {
        "$ref": "defs.schema.json#/$defs/StatusPaneCommand"
      }
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "category",
    "command_config"
  ],
  "unevaluatedProperties": false,
  "$defs": {
    "ProjectBase": {
      "type": "object",
      "properties": {
        "cwd": {
          "type": "string",
          "format": "uri-reference"
        },
        "label": {
          "type": "string"
        },
        "task_project": {
          "type": "string"
        },
        "omitted_panes": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "editor",
              "git"
            ]
          }
        },
        "command_config": {
          "anyOf": [
            {
              "$ref": "defs.schema.json#/$defs/ProjectCommandConfig"
            },
            {
              "type": "string"
            }
          ]
        }
      }
    },
    "NestedProject": {
      "allOf": [
        {
          "$ref": "#/$defs/ProjectBase"
        }
      ],
      "required": [
        "cwd"
      ],
      "unevaluatedProperties": false
    },
    "NestedProjectsConfig": {
      "properties": {
        "show_as_root": {
          "type": "boolean"
        },
        "projects": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/NestedProject"
          }
        }
      }
    }
  }
}