{
  "$schema": "root.schema.json",
  "$id": "https://meepleek.com/schema/defs.schema.json",
  "title": "MeepleekDefs",
  "$defs": {
    "ProjectCategory": {
      "type": "string",
      "enum": [
        "prj",
        "cfg",
        "gd"
      ]
    },
    "ExternalCommandConfig": {
      "type": "object",
      "properties": {
        "path": {
          "type": "string"
        },
        "source": {
          "type": "string",
          "enum": [
            "npm",
            "vscode"
          ]
        }
      },
      "required": [
        "path",
        "source"
      ]
    },
    "MappedCommand": {
      "type": "object",
      "properties": {
        "label": {
          "type": "string"
        },
        "source": {
          "type": "string",
          "enum": [
            "dash",
            "npm",
            "vscode"
          ]
        },
        "cmd": {
          "type": "string"
        },
        "auto_close": {
          "type": "boolean"
        },
        "multi_prefix": {
          "type": "string"
        },
        "env": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        }
      },
      "required": [
        "label",
        "source",
        "cmd",
        "auto_close"
      ]
    },
    "StatusPaneCommand": {
      "type": "object",
      "properties": {
        "label": {
          "type": "string"
        },
        "bind": {
          "type": "string"
        },
        "command": {
          "type": "string"
        },
        "stdout": {
          "type": [
            "boolean",
            "null"
          ]
        },
        "analyzer": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "eslint"
          ]
        }
      },
      "required": [
        "label",
        "bind",
        "command"
      ]
    },
    "ProjectCommandConfig": {
      "type": "object",
      "properties": {
        "status_pane": {
          "type": [
            "array",
            "null"
          ],
          "items": {
            "anyOf": [
              {
                "$ref": "#/$defs/StatusPaneCommand"
              },
              {
                "type": "string"
              }
            ]
          }
        },
        "commands": {
          "type": [
            "array",
            "null"
          ],
          "items": {
            "anyOf": [
              {
                "$ref": "#/$defs/MappedCommand"
              },
              {
                "type": "string"
              }
            ]
          }
        },
        "external_configs": {
          "type": [
            "array",
            "null"
          ],
          "items": {
            "anyOf": [
              {
                "$ref": "#/$defs/ExternalCommandConfig"
              },
              {
                "type": "string"
              }
            ]
          }
        }
      }
    }
  }
}